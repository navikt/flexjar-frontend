        "prettier": "^3.9.5",
        "tailwindcss": "^4.3.3",
        "typescript": "^6.0.3"
    },
    "scripts": {
        "dev": "MOCK_BACKEND=true next dev --turbopack -p 3000 | pino-pretty",
        "local": "LOCAL_BACKEND=true next dev -p 3000 | pino-pretty",
